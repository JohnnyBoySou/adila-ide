{
  "name": "adila-ide",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "bash scripts/build.sh",
    "build:all": "bash scripts/build-all.sh",
    "build:linux": "bash scripts/build-linux.sh",
    "generate": "wails generate module",
    "lint": "bun run lint:go && bun run lint:frontend",
    "lint:go": "go vet ./...",
    "lint:frontend": "cd frontend && bun run lint",
    "fmt": "bun run fmt:go && bun run fmt:frontend",
    "fmt:go": "gofmt -w .",
    "fmt:frontend": "cd frontend && bun run fmt",
    "fmt:check": "gofmt -l . && cd frontend && bun run fmt:check",
    "install:cli": "mkdir -p \"$HOME/.local/bin\" && ln -sf \"$PWD/scripts/adila\" \"$HOME/.local/bin/adila\" && echo 'adila instalado em ~/.local/bin/adila'",
    "benchmark:all": "bash scripts/benchmark.sh .",
    "benchmark:quick": "BENCHTIME=500ms bash scripts/benchmark.sh .",
    "benchmark:fs": "bash scripts/benchmark.sh 'ListDir|ListAllFiles|SearchFiles'",
    "benchmark:git": "bash scripts/benchmark.sh 'ParseStatus'",
    "benchmark:search": "bash scripts/benchmark.sh 'SearchInFiles|CompileSearchRegex'",
    "benchmark:frontend": "bash scripts/benchmark-frontend.sh"
  }
}
